{
  "version": 2,
  "builds": [
    { "src": "backend/index.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "aakash-academy/build" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/index.js" },
    { "source": "/uploads/(.*)", "destination": "/backend/index.js" },
    { "source": "/((?!api|uploads|static|.*\\.).*)", "destination": "/index.html" }
  ]
}
